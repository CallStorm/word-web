# word-web environment
DB_URL=mysql+pymysql://wordweb:wordweb@127.0.0.1:3306/wordweb?charset=utf8mb4
PPT_WEB_JWT_SECRET=change-me-in-production
MAX_CONCURRENT_JOBS=3
DOCKER_RUNNER_IMAGE=word-runner:latest
DOCKER_RUNNER_NETWORK=word-isolated
DOCKER_RUNNER_MEMORY=4g
DOCKER_RUNNER_CPUS=2
DOCKER_RUNNER_TIMEOUT_S=3600
SKIP_EIGHT_CONFIRM_MAX=3
DISPLAY_TIMEZONE=Asia/Shanghai
